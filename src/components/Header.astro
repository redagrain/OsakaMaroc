<style>
  .header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: #FFFFFF;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Adjusted for light background */
    transition: all 0.3s ease;
    color: #333; /* Make text readable on white background */
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 45px; /* Enlarged logo */
    width: auto;
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: #888; /* gray */
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    color: #009FE3; /* primary color */
  }

  .has-dropdown {
    position: relative;
    padding-bottom: 0.5rem; /* Make it easier to hover onto the menu */
  }

  .dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .dropdown-arrow {
    transition: transform 0.3s ease;
  }

  .has-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }
  
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    background: #FFFFFF;
    min-width: 260px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    padding: 0.5rem 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .has-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: block;
    padding: 0.75rem 1.5rem;
    color: #555;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .dropdown-item:hover {
    color: #009FE3;
    background: rgba(0, 159, 227, 0.05);
  }

  .header-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .phone-number {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: #888888;
    font-size: 1rem;
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .phone-number:hover {
    color: #009FE3;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: #888888; 
    background: transparent;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-icon:hover {
    color: #009FE3;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .nav, .header-contact {
      display: none;
    }
  }
</style>
