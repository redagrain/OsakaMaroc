<style>
  .footer {
    background-color: #ffffff;
    color: #666666;
    padding-top: 4rem;
    border-top: 1px solid rgba(0,0,0,0.07);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .footer-logo img {
    height: 32px;
    object-fit: contain;
    filter: none;
    margin-bottom: 1rem;
    display: block;
  }

  .footer-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #888888;
    margin-bottom: 1.5rem;
  }

  .social-icons {
    display: flex;
    gap: 1rem;
  }

  .social-icons a {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: #f4f4f4;
    color: #555555;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, color 0.3s ease;
    text-decoration: none;
  }

  .social-icons a:hover {
    background: #009FE3;
    color: #fff;
  }

  .link-group h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #009FE3;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .link-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0;
    margin: 0;
  }

  .link-group a {
    color: #666666;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .link-group a:hover {
    color: #009FE3;
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.9rem;
    color: #666666;
    line-height: 1.5;
  }

  .contact-list svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: #009FE3;
  }

  .footer-bottom {
    padding: 1.5rem 0;
    color: #aaaaaa;
    font-size: 0.85rem;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  .legal-links {
    display: flex;
    gap: 1.5rem;
  }

  .legal-links a {
    color: #aaaaaa;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .legal-links a:hover {
    color: #009FE3;
  }

  @media (max-width: 900px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 576px) {
    .footer-content {
      grid-template-columns: 1fr;
    }
    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
      justify-content: center;
    }
    .legal-links {
      justify-content: center;
    }
  }
</style>
