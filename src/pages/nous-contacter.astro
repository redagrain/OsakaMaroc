---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Nous Contacter | Osaka Solutions Maroc"
  description="Contactez Osaka Solutions Maroc. Notre équipe est disponible pour vous aider dans toutes vos demandes et répondre à vos besoins en matériels industriels."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>Nous Contacter</h1>
      <p class="breadcrumb"><a href="/">Accueil</a> <span>/</span> Nous Contacter</p>
    </div>
  </section>

  <Contact />
</Layout>

<style>
  /* Hero */
  .page-hero {
    position: relative;
    height: 280px;
    background: url('/images/AboutOsaka.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    margin-top: 80px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 12, 0.65);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: #fff;
  }

  .hero-content h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .breadcrumb {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #009FE3;
  }

  .breadcrumb span {
    margin: 0 0.5rem;
  }
</style>
